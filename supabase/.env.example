# LegalShield — Supabase Edge Function Secrets
# Copy to .env inside this directory for local management
# These are pushed to Supabase via 'supabase secrets set'

# List of API keys for round-robin rotation (comma-separated)
GEMINI_API_KEYS=your-gemini-key-1,your-gemini-key-2
GROQ_API_KEYS=gsk_your-groq-key-1,gsk_your-groq-key-2
EXA_API_KEYS=your-exa-net-search-key
JINA_API_KEYS=your-jina-ai-reader-key
VOYAGE_API_KEYS=your-voyage-key-1,your-voyage-key-2

# Upstash Redis (Semantic Caching & Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# MOMO Payment
MOMO_PARTNER_CODE=MOMOBKUN20180810
MOMO_ACCESS_KEY=WMLB9772WhINCerx
MOMO_SECRET_KEY=qSMC0WnmW6x943iC2Oka382EAtKThB7i

# VNPAY Payment
VNPAY_TMN_CODE=2QXC69SY
