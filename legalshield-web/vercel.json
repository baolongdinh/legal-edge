{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": "vite",
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "VITE_SUPABASE_URL": "@legalshield-supabase-url",
        "VITE_SUPABASE_ANON_KEY": "@legalshield-supabase-anon-key"
    }
}